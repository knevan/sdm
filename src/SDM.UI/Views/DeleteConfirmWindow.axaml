<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SDM.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="420" d:DesignHeight="170"
        x:Class="SDM.UI.Views.DeleteConfirmWindow"
        x:DataType="vm:DeleteConfirmViewModel"
        Title="Delete Download"
        Width="420" Height="170"
        MinWidth="380" MinHeight="150"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Design.DataContext>
        <vm:DeleteConfirmViewModel />
    </Design.DataContext>

    <Grid Margin="16" RowDefinitions="Auto,*,Auto,Auto">
        <!-- Confirmation message -->
        <TextBlock Grid.Row="0"
                   Text="{Binding Message}"
                   TextWrapping="Wrap"
                   FontSize="14" />

        <!-- Delete from disk checkbox -->
        <CheckBox Grid.Row="2"
                  Content="Also delete file(s) from disk"
                  IsChecked="{Binding DeleteFromDisk}"
                  Margin="0,8,0,0" />

        <!-- Action buttons (right-aligned) -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0"
                    Spacing="10">
            <Button Content="Delete"
                    Command="{Binding ConfirmDeleteCommand}"
                    Padding="16,5"
                    Classes="accent" />
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    HotKey="Escape"
                    Padding="16,5" />
        </StackPanel>
    </Grid>
</Window>
